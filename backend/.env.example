# PULSE — Environment Variables
# Copy this file to backend/.env and fill in your values.
# DO NOT commit .env to version control.

# ── Hardware ──────────────────────────────────────────────────────
# cuda = NVIDIA GPU, cpu = Intel Iris Xe / integrated graphics
DEVICE=cpu

# ── Camera / Sensor ───────────────────────────────────────────────
# Measure the physical height of your phone above the road surface (metres).
# This is Anchor 2 for metric scale recovery. Measure once with a ruler.
CAMERA_HEIGHT_M=1.20

# ── Visual Assessment (Choose ONE) ────────────────────────────────
# Option A: Gemini API (RECOMMENDED for Intel Iris Xe)
#   - Fast (2-5s per segment), free tier, excellent quality
#   - Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Option B: Ollama CPU Mode (fully local, slower)
#   - llama3.2-vision:11b-q4 = 7GB RAM, ~15-30s per segment
#   - llava:7b-q4 = 4GB RAM, ~10-15s per segment (lower quality)
#   - Leave GEMINI_API_KEY empty to use Ollama
VLM_OLLAMA_MODEL=llama3.2-vision:11b-q4
VLM_OLLAMA_FALLBACK=llava:7b-q4

# Option C: Disable visual assessment
#   - Leave GEMINI_API_KEY empty and don't pull Ollama models
#   - IRI + depth still work (most important metrics)

# ── Gemini (Google AI) ────────────────────────────────────────────
# Used for narrative text generation (economic cascade, PMGSY applications)
# AND visual assessment if GEMINI_API_KEY is set above
GEMINI_MODEL=gemini-2.5-flash

OLLAMA_HOST=http://localhost:11434

# ── Depth Model (HuggingFace) ─────────────────────────────────────
# ~100 MB, runs on CPU for Intel Iris Xe (~2-5 fps, post-process recorded video)
DEPTH_MODEL=depth-anything/Depth-Anything-V2-Small-hf

# ── Pipeline Parameters ───────────────────────────────────────────
SEGMENT_LENGTH_M=100          # IRI computed per 100m road segment
MIN_SPEED_KMH=20              # Below this, IRI readings are flagged invalid
MAX_DEPTH_M=8.0               # Maximum valid road surface depth for point cloud
IRI_SAMPLE_RATE=200           # Accelerometer sampling rate (Hz)

# ── Backend ───────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Economic Cascade — Real Data APIs ─────────────────────────────
# Overpass API (OpenStreetMap) — free, no key needed
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# data.gov.in — district crop production statistics
# Free registration: https://data.gov.in/user/register
DATA_GOV_API_KEY=your-data-gov-in-key-here

# WorldPop — real population counts
# Free, no key needed. Latest complete dataset year:
WORLDPOP_YEAR=2020

# Search radius for OSM context (schools, PHCs, farms) in metres
ECONOMIC_RADIUS_M=3000

# ── Paths ─────────────────────────────────────────────────────────
CALIBRATION_FILE=calibration/camera_params.json
ACOUSTIC_MODEL_FILE=models/acoustic_model.pkl
OUTPUT_DIR=output/reports

# ── Testing / Development ─────────────────────────────────────
TEST_MODE=false               # Set to 'true' to allow low-speed IRI testing (5 km/h minimum)

# ── Depth Calibration ─────────────────────────────────────────
DEPTH_SCALE_CALIBRATION=0.05  # Adjust if rut depths are too high (lower value) or too low (higher value)

# ── Visual Odometry (DPVO) ────────────────────────────────────
# DPVO service running in WSL Ubuntu (see DPVO_WSL_INTEGRATION.md)
DPVO_SERVICE_URL=http://localhost:5555
DPVO_ENABLED=true             # Set to 'false' to disable DPVO and use 2/3 scale anchors
